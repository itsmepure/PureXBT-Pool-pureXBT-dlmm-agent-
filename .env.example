# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: DeepSeek (default)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_deepseek_api_key_here

# Option B: OpenRouter
# OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Option C: LM Studio (local) — uncomment these and comment out above
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here
GMGN_API_KEY=your_gmgn_api_key_here

# ── HiveMind (optional) ───────────────────────────────────────────────────────
HIVE_MIND_URL=https://api.agentmeridian.xyz
HIVE_MIND_API_KEY=your_hivemind_api_key_here

# ── Discord Listener (optional) ───────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_CHANNEL_IDS=channel_id_1,channel_id_2
DISCORD_MIN_FEES_SOL=5

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dashboard Auth (optional) ─────────────────────────────────────────────────
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASS=your_password_here
DASHBOARD_PREVIEW_ENABLED=true

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
